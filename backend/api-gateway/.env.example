# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Service URLs (for routing to microservices)
AUTH_SERVICE_URL=http://localhost:3001
EVENT_SERVICE_URL=http://localhost:3002
MEDIA_SERVICE_URL=http://localhost:3003
USER_SERVICE_URL=http://localhost:3004
REVENUE_ENGINE_URL=http://localhost:3005

# Database (if needed for gateway-specific data)
DATABASE_URL=postgresql://user:password@localhost:5432/api_gateway

# Logging
LOG_LEVEL=info

# Security
JWT_SECRET=your-super-secret-jwt-key-here
API_KEY=your-api-gateway-key

# Rate Limiting (if implemented)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100